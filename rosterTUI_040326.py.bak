# ==========================================
# ⚡ REGEX PRECOMPILE (Hot Paths)
# ==========================================
RE_TIME_RANGE = re.compile(r'(\d{1,2}[:hH]\d{2}(?::\d{2})?)\s*[-–]\s*(\d{1,2}[:hH]\d{2}(?::\d{2})?)')
RE_TIME = re.compile(r'(\d{1,2}[:hH]\d{2})')
RE_ROUTE = re.compile(r'^[A-Z]{3}\s*(?:-|–|—)\s*[A-Z]{3}$')
RE_PHONE = re.compile(r'^0\d{9,11}$')
RE_ID6 = re.compile(r'^\d{6}$')
RE_DATE = re.compile(r'(\d{1,2}[./-]\d{1,2}[./-](?:\d{4}|\d{2}))')
RE_SHIFT_TIME_PATTERN = re.compile(r'\d{1,2}[:hH]\d{2}(?::\d{2})?\s*[-–]\s*\d{1,2}[:hH]\d{2}(?::\d{2})?')
RE_HEADER_DATE_PATTERN = re.compile(r'NGÀY.*?(\d{1,2}[./-]\d{1,2}[./-](?:\d{4}|\d{2}))')
RE_ENGLISH_DATE_PATTERN = re.compile(r'(?:DATE|PLAN|FOR|ON).*?(\d{1,2})\s*([A-Z]{3})\s*(\d{4}|\d{2})', re.I)
RE_ZONE_PATTERN = re.compile(r'(.*)\((.*)\)')
RE_MULTIPLE_SPACES = re.compile(r' +')

ENGLISH_MONTHS = {
    "JAN": "01", "FEB": "02", "MAR": "03", "APR": "04", "MAY": "05", "JUN": "06",
    "JUL": "07", "AUG": "08", "SEP": "09", "OCT": "10", "NOV": "11", "DEC": "12"
}

# --- CELL CLASSIFICATION BITMASK ---
CELL_ROUTE = 1
CELL_TIME  = 2
CELL_OFF   = 4
CELL_NAME  = 8

# ==========================================
# 💾 DATABASE LAYER
# ==========================================
DB_LOCK = threading.RLock()

def get_db():
    conn = sqlite3.connect(DB_FILE, check_same_thread=False, isolation_level=None)
    conn.row_factory = sqlite3.Row
    conn.execute('PRAGMA journal_mode=WAL;')
    return conn

@contextmanager
def db_conn():
    conn = get_db()
    try:
        yield conn
    finally:
        conn.close()

def init_db():
    with DB_LOCK:
        conn = get_db()
        c = conn.cursor()
        c.execute('''CREATE TABLE IF NOT EXISTS work_schedule
                     (work_date TEXT PRIMARY KEY,
                      full_data TEXT,
                      date_iso TEXT,
                      last_updated TIMESTAMP DEFAULT CURRENT_TIMESTAMP)''')
        c.execute("CREATE INDEX IF NOT EXISTS idx_work_schedule_date_iso ON work_schedule(date_iso)")
        conn.commit()
        conn.close()

def load_history(limit=60, filter_mode="All"):
    with db_conn() as conn:
        c = conn.cursor()
        where = ""
        params = []
        if filter_mode == "This Month":
            now = datetime.now()
            start = now.replace(day=1).strftime("%Y-%m-%d")
            next_start = (now.replace(day=1) + timedelta(days=32)).replace(day=1).strftime("%Y-%m-%d")
            where = "WHERE date_iso >= ? AND date_iso < ?"
            params.extend([start, next_start])
        query = f"SELECT work_date, full_data FROM work_schedule {where} ORDER BY date_iso DESC LIMIT ?"
        params.append(limit)
        c.execute(query, params)
        return [dict(r) for r in c.fetchall()]

def save_entries_bulk(entries):
    if not entries: return
    with DB_LOCK:
        with db_conn() as conn:
            data_tuples = []
            for entry in entries:
                date_str = normalize_date_str(entry['date'])
                iso_date = to_iso_date(date_str)
                json_data = json.dumps(entry, ensure_ascii=False, default=str)
                data_tuples.append((date_str, json_data, iso_date))
            conn.execute("BEGIN IMMEDIATE")
            conn.executemany("INSERT OR REPLACE INTO work_schedule (work_date, full_data, date_iso) VALUES (?, ?, ?)", data_tuples)
            conn.commit()

def save_entry_overwrite(date_str, new_data):
    save_entries_bulk([new_data])

def clear_db():
    with DB_LOCK:
        with db_conn() as conn:
            conn.execute("DELETE FROM work_schedule")
            conn.commit()

# ==========================================
# 🧹 PARSING HELPERS & ENGINE
# ==========================================
_cell_norm_cache = {}
_cell_norm_cache_lock = threading.Lock()

def norm_cell(cell):
    with _cell_norm_cache_lock:
        if cell not in _cell_norm_cache:
            _cell_norm_cache[cell] = str(cell).upper().strip()
        return _cell_norm_cache[cell]

def get_cell_flags(cell):
    if not cell: return 0
    s = norm_cell(cell)
    flags = 0
    if RE_ROUTE.match(s): flags |= CELL_ROUTE
    if RE_TIME_RANGE.search(s): flags |= CELL_TIME
    if s in ["OFF", "HỌC", "NGHỈ", "PHÉP", "ĐI HỌC", "NGHI", "PHEP"]: flags |= CELL_OFF
    return flags

def is_valid_name_generic(text: str) -> bool:
    if not text: return False
    text = str(text).replace('\n', ' ').strip()
    if len(text) < 4: return False
    if any(char.isdigit() for char in text): return False
    if not any(ch.isalpha() for ch in text): return False
    if RE_ROUTE.match(text.upper()): return False
    blocklist = {"AEROBRIDGE", "PASSENGER", "CHARTER", "CARGO", "COMMERCIAL", "SCHEDULE", "OPERATION", "AIRPORT", "CONTROL", "FLIGHT", "PLAN", "LIST", "FROM", "TO", "REMARK", "STATUS"}
    text_upper = text.upper()
    if text_upper in blocklist: return False
    if any(w in blocklist for w in text_upper.split()): return False
    return True

def fuzzy_match_markers(text: str, markers: list, threshold: int = 85) -> int:
    count = 0
    text_upper = text.upper()
    for marker in markers:
        marker_upper = marker.upper()
        if marker_upper in text_upper: count += 1; continue
        if fuzz.partial_ratio(text_upper, marker_upper) >= threshold: count += 1
    return count

def is_valid_roster_year(date_obj):
    if not date_obj: return False
    try:
        if isinstance(date_obj, datetime): year = date_obj.year
        elif isinstance(date_obj, str):
            norm = normalize_date_str(date_obj)
            parts = norm.split(".")
            year = int(parts[2]) if len(parts) == 3 else 0
        else: return False
        return 2020 <= year <= 2100
    except Exception: return False

def normalize_date_str(date_str):
    if not date_str or date_str == "Unknown": return date_str
    cleaned = date_str.replace("/", ".").replace("-", ".").replace(" ", ".")
    while ".." in cleaned: cleaned = cleaned.replace("..", ".")
    parts = cleaned.split(".")
    if len(parts) == 3:
        d, m, y = parts
        d, m = d.zfill(2), m.zfill(2)
        if len(y) == 2: y = "20" + y
        return f"{d}.{m}.{y}"
    return cleaned

def to_iso_date(date_str):
    norm_date = normalize_date_str(date_str)
    for fmt in ("%d.%m.%Y", "%d/%m/%Y", "%d-%m-%Y", "%d.%m.%y"):
        try: return datetime.strptime(norm_date, fmt).strftime("%Y-%m-%d")
        except ValueError: continue
    raise ValueError(f"Invalid date: {date_str}")

def normalize_time_range(cell):
    if not cell: return None
    s = str(cell).upper().strip()
    match = RE_TIME_RANGE.search(s)
    return f"{match.group(1)}-{match.group(2)}" if match else None

def build_row_signals(rows, max_rows=200):
    time_counts, off_count, total_time_entries = defaultdict(int), 0, 0
    route_rows, name_near_route, all_names = set(), set(), defaultdict(int)
    for r_idx, row in enumerate(rows[:max_rows]):
        for c_idx, cell in enumerate(row):
            if not cell: continue
            flags = get_cell_flags(cell)
            if flags & CELL_TIME:
                tr = normalize_time_range(cell)
                if tr: time_counts[tr] += 1; total_time_entries += 1
            if flags & CELL_OFF: off_count += 1
            if flags & CELL_ROUTE:
                route_rows.add(r_idx)
                for offset in (-2, -1, 1, 2):
                    if 0 <= c_idx + offset < len(row):
                        neighbor = row[c_idx + offset]
                        if is_valid_name_generic(neighbor):
                            name_near_route.add(str(neighbor).strip())
                            all_names[str(neighbor).strip()] += 1
        if total_time_entries >= 10 and off_count >= 10: break
    return {"time_counts": time_counts, "total_time_entries": total_time_entries, "off_count": off_count, "route_count": len(route_rows), "distinct_names": len(all_names), "name_near_route_count": len(name_near_route)}

def identify_sheet_type(rows, sheet_name=""):
    if not rows: return "SKIP"
    signals = build_row_signals(rows)
    if signals["route_count"] >= 3 and signals["name_near_route_count"] >= 2: return "FLIGHT"
    if signals["total_time_entries"] >= 4 and signals["off_count"] >= 3: return "SHIFT"
    return "SKIP"

def normalize_text(text: str) -> str:
    if text is None: return ""
    text = str(text)
    if text.endswith('.0'): text = text[:-2] 
    return unicodedata.normalize('NFC', text).strip()

def clean_val(val):
    if val is None: return ""
    s = str(val).strip()
    if s.endswith(".0"): return s[:-2]
    return "" if s.lower() == 'nan' else s

def clean_time(t_str: str) -> str:
    if not t_str: return ""
    t_str = t_str.upper().replace("H", ":").replace(".", ":").replace("G", ":").strip()
    match = RE_TIME_RANGE.search(t_str)
    if match:
        try:
            start = RE_TIME.search(match.group(1)).group(1)
            end = RE_TIME.search(match.group(2)).group(1)
            return f"{start} - {end}"
        except Exception: return t_str
    match = RE_TIME.search(t_str)
    return match.group(1) if match else t_str

def compile_alias_regex(aliases):
    clean_aliases = [normalize_text(a).strip() for a in aliases if normalize_text(a).strip()]
    if not clean_aliases: return None
    clean_aliases.sort(key=len, reverse=True)
    chars = "a-zA-Z0-9àáạảãâầấậẩẫăằắặẳẵèéẹẻẽêềếệểễìíịỉĩòóọỏõôồốộổỗơờớợởỡùúụủũưừứựửữỳýỵỷỹđ"
    boundary_start, boundary_end = f"(?:^|[^{chars}])", f"(?:$|[^{chars}])"
    return re.compile(boundary_start + r"(" + "|".join(map(re.escape, clean_aliases)) + r")" + boundary_end, re.IGNORECASE)

def check_name_match(cell_content, alias_regex):
    if not cell_content or not alias_regex: return False
    return bool(alias_regex.search(normalize_text(cell_content)))

def is_valid_route(s): return bool(RE_ROUTE.match(str(s).strip().upper()))

def extract_date_smart(rows, filename):
    RE_ISO_DATE = re.compile(r'(\d{4})-(\d{2})-(\d{2})')
    for row in rows[:15]:
        for val in row[:50]:
            iso_match = RE_ISO_DATE.search(str(val or ""))
            if iso_match:
                y, m, d = iso_match.groups()
                d_str = f"{d}.{m}.{y}"
                if is_valid_roster_year(d_str): return normalize_date_str(d_str)
    for row in rows[:10]:
        row_str = " ".join([str(x) for x in row[:50] if x]).upper()
        match = RE_HEADER_DATE_PATTERN.search(row_str)
        if match and is_valid_roster_year(match.group(1)): return normalize_date_str(match.group(1))
    match = RE_DATE.search(filename)
    if match and is_valid_roster_year(match.group(1)): return normalize_date_str(match.group(1))
    return "Unknown"

def parse_row_items(row_raw): return [clean_val(x) for x in row_raw[:50]]

def find_name_index_in_list(clean_items, alias_regex):
    for i, item in enumerate(clean_items):
        if check_name_match(item, alias_regex): return i
    return -1

def process_row_content_v2(clean_items, name_idx, alias_regex=None, inside_cols=None, shift_col=None, is_maca=False):
    if not clean_items: return None
    has_route = any(is_valid_route(x) for x in clean_items)
    if name_idx != -1 and not has_route:
        if shift_col is not None and shift_col < len(clean_items):
            v = str(clean_items[shift_col] or "").upper()
            if RE_TIME_RANGE.search(v): return {'type': 'shift', 'data': clean_time(clean_items[shift_col])}
            if "HỌC" in v: return {'type': 'shift', 'data': 'HỌC'}
            if v in ["OFF", "NGHỈ", "PHÉP"]: return {'type': 'shift', 'data': v}
        right_side = clean_items[name_idx+1 : name_idx+11]
        for item in right_side:
            if RE_TIME_RANGE.search(str(item)): return {'type': 'shift', 'data': clean_time(item)}
        for item in right_side:
            v = str(item).upper()
            if "HỌC" in v: return {'type': 'shift', 'data': 'HỌC'}
            if v in ["OFF", "NGHỈ", "PHÉP"]: return {'type': 'shift', 'data': v}
        if any(RE_PHONE.match(str(x).replace(".", "").replace(" ", "")) for x in right_side): return {'type': 'shift', 'data': 'OFF'}
        if shift_col is not None and shift_col < len(clean_items) and not clean_val(clean_items[shift_col]): return {'type': 'shift', 'data': 'OFF'}
    
    route_idx = -1
    for i, item in enumerate(clean_items):
        if is_valid_route(item): route_idx = i; break
    if route_idx != -1:
        call_val, type_val = clean_items[route_idx-1] if route_idx>0 else "", clean_items[route_idx-2] if route_idx>1 else ""
        anchor_idx = -1
        for i in range(route_idx+1, len(clean_items)):
            if RE_TIME.search(clean_items[i]): anchor_idx = i
            if clean_items[i] and len(clean_items[i])<=4 and anchor_idx!=-1: anchor_idx=i; break
        if anchor_idx == -1: anchor_idx = route_idx
        times = [clean_time(clean_items[i]) for i in range(anchor_idx, route_idx, -1) if RE_TIME.search(clean_items[i])]
        r_close, r_open = times[0] if len(times)>=1 else '', times[1] if len(times)>=2 else ''
        r_bay = clean_items[anchor_idx] if anchor_idx<len(clean_items) and len(clean_items[anchor_idx])<=4 and not RE_TIME.search(clean_items[anchor_idx]) else ''
        found_flights = []
        if inside_cols:
            for ci in inside_cols:
                if ci<len(clean_items) and check_name_match(clean_items[ci], alias_regex):
                    found_flights.append({'Type':type_val,'Call':call_val,'Route':clean_items[route_idx],'Open':r_open,'Close':r_close,'Bay':r_bay,'Names':clean_items[ci],'Zone':'Băng chuyền'})
        else:
            for offset in range(1,5):
                idx = anchor_idx+offset
                if idx>=len(clean_items): break
                if check_name_match(clean_items[idx], alias_regex):
                    found_flights.append({'Type':type_val,'Call':call_val,'Route':clean_items[route_idx],'Open':r_open,'Close':r_close,'Bay':r_bay,'Names':clean_items[idx],'Zone':'Băng chuyền' if offset==1 else 'Sân đỗ'})
        if found_flights: return {'type':'flight_list','data':found_flights}
        if name_idx == -1: return {'type':'flight','data':{'Type':type_val,'Call':call_val,'Route':clean_items[route_idx],'Open':r_open,'Close':r_close,'Bay':r_bay,'Names':'','Zone':''}}
    return None

def find_header_mapping(rows):
    TARGETS = {"name":["HỌ VÀ TÊN","HO VA TEN","TÊN NHÂN VIÊN"],"id":["MÃ NV","MA NV","MANV","ID"],"shift":["CA LÀM VIỆC","TÊN CA","MÃ CA","SHIFT"],"phone":["SĐT","PHONE"]}
    best_row, final_map, best_score = -1, {}, 0
    for r_idx in range(min(20, len(rows))):
        row = [str(c or "").strip().upper() for c in rows[r_idx]]
        curr_map, score = {}, 0
        for key, kws in TARGETS.items():
            for c_idx, cell in enumerate(row):
                if any(kw in cell for kw in kws): curr_map[key]=c_idx; score+=1; break
        if score > best_score: best_score, best_row, final_map = score, r_idx, curr_map
    return best_row, final_map

def process_sheet_v3(rows, alias_regex, date_str, filename, sheet_obj=None):
    with _cell_norm_cache_lock: _cell_norm_cache.clear()
    result = {"date": date_str, "shift": None, "flights": []}
    current_zone, zone_idx = "", 0
    ZONES = ["SÂN ĐỖ", "BĂNG CHUYỀN", "TRẢ HÀNH LÝ"]
    header_idx, mapping = find_header_mapping(rows)
    shift_col = mapping.get('shift')
    is_maca = sheet_obj and "MÃ CA" in norm_cell(sheet_obj)
    inside_cols, header_found = [], False
    processed = set()
    for r_idx, row in enumerate(rows):
        if r_idx in processed: continue
        items = parse_row_items(row)
        cells_upper = [norm_cell(x) for x in items if x]
        def row_has(s): return any(s in c for c in cells_upper)
        if not header_found and row_has("SERIAL") and row_has("CALLSIGN"):
            for ci, cell in enumerate(items):
                cv = norm_cell(cell or "")
                if any(x in cv for x in ["HL ĐI", "HÀNH LÝ ĐI", "TRẢ HL ĐẾN"]): inside_cols.append(ci)
            header_found = True; continue
        if row_has("SÂN ĐỖ"): current_zone, zone_idx = "SÂN ĐỖ", 0
        elif row_has("BĂNG CHUYỀN"): current_zone, zone_idx = "BĂNG CHUYỀN", 1
        elif row_has("TRẢ HÀNH LÝ"): current_zone, zone_idx = "TRẢ HÀNH LÝ", 2
        if not current_zone and zone_idx < len(ZONES): current_zone = ZONES[zone_idx]
        name_idx = find_name_index_in_list(items, alias_regex)
        if name_idx == -1: continue
        res = process_row_content_v2(items, name_idx, alias_regex, inside_cols=inside_cols, shift_col=shift_col, is_maca=is_maca)
        if res:
            if res['type'] == 'shift':
                fs = res['data']
                if current_zone and fs not in ["OFF", "HỌC"]: fs = f"{fs} ({current_zone})"
                result['shift'] = fs
            elif res['type'] in ['flight', 'flight_list']:
                flights = res['data'] if res['type'] == 'flight_list' else [res['data']]
                outbound = None
                if r_idx + 1 < len(rows):
                    res_next = process_row_content_v2(parse_row_items(rows[r_idx+1]), -1, alias_regex, inside_cols=inside_cols)
                    if res_next and res_next['type'] in ['flight', 'flight_list']:
                        outbound = res_next['data'][0] if res_next['type'] == 'flight_list' else res_next['data']
                        processed.add(r_idx+1)
                for f in flights:
                    if outbound: f['Call'], f['Route'] = outbound['Call'], outbound['Route']
                    result['flights'].append(f)
    return result

def parse_file(file_stream, filename, alias_regex):
    processed_data = []
    try:
        workbook = CalamineWorkbook.from_filelike(file_stream)
        for sheet_name in workbook.sheet_names:
            rows = workbook.get_sheet_by_name(sheet_name).to_python()
            if identify_sheet_type(rows, sheet_name) == "SKIP": continue
            date_str = extract_date_smart(rows, filename)
            if date_str == "Unknown": continue
            res = process_sheet_v3(rows, alias_regex, date_str, filename, sheet_name)
            if res['shift'] or res['flights']: processed_data.append(res)
    except Exception: pass
    return processed_data

def consolidate_file_results(results):
    merged = {}
    for res in results:
        d = res['date']
        if d not in merged: merged[d] = res
        else:
            if res.get('shift') and res['shift'] not in ['OFF', None, '']: merged[d]['shift'] = res['shift']
            existing_calls = {f['Call'] for f in merged[d].get('flights', [])}
            for f in res.get('flights', []):
                if f['Call'] not in existing_calls: merged[d]['flights'].append(f)
    return merged.values()

# ==========================================
# 📤 EXPORT HELPERS
# ==========================================
def sanitize_formula(val):
    if val and isinstance(val, str):
        stripped = val.lstrip()
        if stripped.startswith(('=', '+', '-', '@')): return "'" + val
    return val

def generate_ical_content():
    rows = load_history()
    if not rows: return None
    ical = ["BEGIN:VCALENDAR", "VERSION:2.0", "PRODID:-//RosterMaster//v6.0//EN", "CALSCALE:GREGORIAN", "METHOD:PUBLISH"]
    for r in rows:
        try:
            date_str = r['work_date']
            data = json.loads(r['full_data'])
            dt_obj = datetime.strptime(date_str, "%d.%m.%Y")
            for f in data.get('flights', []):
                t_o, t_c = f.get('Open', ''), f.get('Close', '')
                m_o, m_c = RE_TIME.search(t_o), RE_TIME.search(t_c)
                if not m_o or not m_c: continue
                h_o, min_o = map(int, m_o.group(1).replace('H',':').replace('.',':').split(':'))
                h_c, min_c = map(int, m_c.group(1).replace('H',':').replace('.',':').split(':'))
                dt_start = dt_obj.replace(hour=h_o, minute=min_o)
                dt_end = dt_obj.replace(hour=h_c, minute=min_c)
                if dt_end < dt_start: dt_end += timedelta(days=1)
                ical.extend(["BEGIN:VEVENT", f"DTSTART:{dt_start.strftime('%Y%m%dT%H%M%S')}", f"DTEND:{dt_end.strftime('%Y%m%dT%H%M%S')}", f"SUMMARY:{sanitize_formula(f.get('Call',''))} ({f.get('Route','')})", f"DESCRIPTION:Bay: {f.get('Bay','')}", "END:VEVENT"])
        except Exception: continue
    ical.append("END:VCALENDAR")
    return "\r\n".join(ical)

def generate_csv_content():
    rows = load_history()
    if not rows: return None
    output = io.StringIO()
    writer = csv.writer(output)
    writer.writerow(["Date", "Shift", "Type", "Call", "Route", "Open", "Close", "Bay", "Names"])
    for r in rows:
        try:
            data = json.loads(r['full_data'])
            flights = data.get('flights', [])
            if not flights:
                writer.writerow([r['work_date'], data.get('shift', ''), "", "", "", "", "", "", ""])
            else:
                for f in flights:
                    writer.writerow([r['work_date'], data.get('shift', ''), f.get('Type',''), f.get('Call',''), f.get('Route',''), f.get('Open',''), f.get('Close',''), f.get('Bay',''), f.get('Names','')])
        except Exception: continue
    return output.getvalue()

# ==========================================
# 🔄 INGEST & ALIASES
# ==========================================

def get_aliases():
    alias_file = "v42_aliases.txt"
    if os.path.exists(alias_file):
        with open(alias_file, 'r', encoding='utf-8') as f:
            aliases = f.read()
    else:
        aliases = "Ấn, ẨN, Ẩn, Nguyễn Ngọc Ấn, NGỌC ẤN, Nguyễn Ngọc Ẩn, NGỌC ẨN"
    return [x.strip() for x in aliases.split(",")]

class AliasModal(ModalScreen):
    def compose(self) -> ComposeResult:
        with Vertical(classes="modal-container"):
            yield Label("CHỈNH SỬA DANH SÁCH TÊN (Phân cách bằng dấu phẩy)")
            yield TextArea(self.load_aliases(), id="alias-input")
            with Horizontal():
                yield Button("Lưu", variant="success", id="save-alias")
                yield Button("Hủy", variant="error", id="cancel-alias")

    def load_aliases(self) -> str:
        return ",".join(get_aliases())

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "save-alias":
            text = self.query_one("#alias-input").text
            with open("v42_aliases.txt", "w", encoding="utf-8") as f:
                f.write(text)
            self.dismiss(True)
        else:
            self.dismiss(False)

class RosterCard(Static):
    """Compact roster entry - single line header with optional expandable flights."""
    
    def __init__(self, work_date, data, is_first=False, **kwargs):
        super().__init__(**kwargs)
        self.work_date = work_date
        self.data = data
        self.is_first = is_first

    def compose(self) -> ComposeResult:
        shift_raw = self.data.get("shift") or "--"
        flights = self.data.get("flights") or []
        
        # Extract zone from shift text
        zone = ""
        time_part = shift_raw
        match = RE_ZONE_PATTERN.search(shift_raw)
        if match:
            time_part = match.group(1).strip()
            zone = match.group(2).strip().upper()
            
        color = self._get_shift_color(time_part)
        date_label = self._format_date(self.work_date)
        
        # Compact single-line header
        with Vertical(classes=f"card border-{color}"):
            with Horizontal(classes="card-header"):
                # Date column - compact
                yield Label(date_label, classes="date-label")
                
                # Zone badge (prominent display)
                if zone:
                    yield Label(zone, classes="zone-badge")
                
                # Shift badge
                yield Label(time_part, classes=f"shift-label text-{color}")
                
                # Flight count badge (if any)
                if flights:
                    yield Label(f"[{len(flights)}]", classes="flight-count")
                
                # Actions
                yield Button("📋", variant="primary", id="copy-btn")
            
            # Flight details - only if present, auto-expand first card
            if flights:
                # First card auto-expands (collapsed=False when is_first)
                with Collapsible(title=f"Bay ({len(flights)})", collapsed=not self.is_first):
                    # Wrap DataTable in ScrollableContainer for touch scrolling
                    with ScrollableContainer(classes="flight-scroll"):
                        table = DataTable(zebra_stripes=True)
                        table.add_columns("Call", "Route", "Time", "Bay", "Name")
                        for f in flights:
                            table.add_row(
                                f.get("Call", ""),
                                f.get("Route", ""),
                                f"{f.get('Open', '')}-{f.get('Close', '')}",
                                f.get("Bay", ""),
                                f.get("Names", "")
                            )
                        yield table

    def _format_date(self, date_str: str) -> str:
        """Format date as compact Vietnamese weekday."""
        try:
            dt = datetime.strptime(date_str, "%d.%m.%Y")
            days = ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN']
            return f"{days[dt.weekday()]} {dt.strftime('%d/%m')}"
        except Exception:
            return date_str

    def _get_shift_color(self, shift: str) -> str:
        """Map shift type to color theme."""
        if shift == "OFF":
            return "red"
        if "HỌC" in shift.upper():
            return "blue"
        return "green" if shift != "--" else "gray"

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "copy-btn":
            text = self._build_copy_text()
            try:
                subprocess.run(["termux-clipboard-set"], input=text.encode("utf-8"), check=True)
                self.app.notify("✓ Copied!")
            except Exception as e:
                self.app.notify(f"Copy failed: {e}", severity="error")

    def _build_copy_text(self) -> str:
        """Generate clipboard text."""
        shift = self.data.get("shift", "--")
        lines = [f"{self._format_date(self.work_date)} | {shift}"]
        for f in self.data.get("flights", []):
            lines.append(
                f"✈ {f.get('Call','')} {f.get('Route','')} "
                f"{f.get('Open','')}-{f.get('Close','')} "
                f"[{f.get('Bay','')}] {f.get('Names','')}"
            )
        return "\n".join(lines)

class RosterApp(App):
    CSS = """
    /* === COMPACT MODERN THEME === */
    Screen {
        background: $background;
    }
    
    /* Header bar - status/settings area */
    .header-bar {
        dock: top;
        height: 3;
        background: $surface;
        border-bottom: tall $primary;
        padding: 0 1;
    }
    .header-left {
        width: 1fr;
        align: left middle;
    }
    .header-right {
        width: auto;
        align: right middle;
    }
    .status-indicator {
        color: $success;
        text-style: bold;
    }
    .status-running {
        color: $warning;
    }
    .app-title {
        text-style: bold;
        color: $primary;
    }
    .header-btn {
        margin-left: 1;
        min-width: 6;
        height: 2;
    }
    
    /* Modal - compact, auto-sized */
    .modal-container {
        padding: 1 2;
        background: $surface;
        border: tall $primary;
        width: 60;
        height: auto;
        max-height: 70%;
        align: center middle;
    }
    #alias-input {
        height: 12;
        margin-bottom: 1;
    }
    
    /* Card - ultra compact */
    .card {
        margin: 0 1;
        padding: 0 1;
        background: $surface;
        height: auto;
        min-height: 1;
    }
    .border-green { border-left: outer $success; }
    .border-red { border-left: outer $error; }
    .border-blue { border-left: outer #58a6ff; }
    .border-gray { border-left: outer #484848; }
    
    /* Inline header layout */
    .card-header {
        height: 1;
        align: left middle;
        padding: 0;
    }
    .date-label {
        text-style: bold;
        color: $text;
        min-width: 8;
    }
    
    /* Zone badge - prominent display */
    .zone-badge {
        background: $primary;
        color: $text;
        text-style: bold;
        padding: 0 1;
        margin-left: 1;
        min-width: 3;
    }
    
    .shift-label {
        width: 1fr;
        text-style: bold;
        margin-left: 1;
    }
    .text-green { color: $success; }
    .text-red { color: $error; }
    .text-blue { color: #58a6ff; }
    .text-gray { color: $text-muted; }
    
    /* Flight count badge */
    .flight-count {
        color: $warning;
        text-style: bold;
        width: 4;
        text-align: center;
    }
    
    /* Copy button - minimal */
    #copy-btn {
        width: 4;
        min-width: 4;
        height: 1;
        padding: 0 1;
    }
    
    /* Collapsible - compact header */
    Collapsible {
        margin-top: 0;
        padding: 0;
    }
    Collapsible Header {
        height: 1;
        padding: 0 1;
        text-style: dim;
    }
    
    /* Flight scroll container - enables touch scrolling */
    .flight-scroll {
        height: auto;
        max-height: 15;
        scrollbar-size: 1 1;
    }
    
    /* DataTable - compact rows */
    DataTable {
        height: auto;
        padding: 0;
    }
    DataTable .datatable--header {
        text-style: bold;
        background: $surface-darken-1;
    }
    DataTable .datatable--cursor {
        background: $primary-darken-2;
    }
    
    /* Main container scrollbar */
    #roster-container {
        scrollbar-size: 1 1;
    }
    
    /* Dark mode toggle */
    .dark-mode {
        background: $surface-darken-3;
    }
    """

    BINDINGS = [
        Binding("q", "scan", "Quét Zalo", show=True),
        Binding("a", "edit_aliases", "Tên", show=True),
        Binding("r", "refresh", "Làm mới", show=True),
        Binding("i", "export_ical", "iCal", show=True),
        Binding("c", "export_csv", "CSV", show=True),
        Binding("d", "toggle_dark", "Sáng/Tối", show=True),
        Binding("escape", "quit", "Thoát", show=True),
    ]

    # Reactive status for header bar
    status_text = reactive("Sẵn sàng")
    status_running = reactive(False)

    def compose(self) -> ComposeResult:
        # Custom header bar with status and action buttons
        with Horizontal(classes="header-bar"):
            with Horizontal(classes="header-left"):
                yield Label("RM", classes="app-title")
                yield Label(" | ", classes="status-indicator")
                yield Label(self.status_text, id="status-label", classes="status-indicator")
            with Horizontal(classes="header-right"):
                yield Button("◐", id="theme-btn", variant="primary", classes="header-btn")
                yield Button("✕", id="quit-btn", variant="error", classes="header-btn")
        
        with ScrollableContainer(id="roster-container"):
            yield Vertical(id="roster-list")
        yield Footer()

    def on_mount(self) -> None:
        init_db()
        os.makedirs(AUTO_INGEST_DIR, exist_ok=True)
        os.makedirs(EXPORT_DIR, exist_ok=True)
        self.status_text = "Sẵn sàng"
        self.refresh_roster()
        self.set_interval(INGEST_INTERVAL, self.action_scan)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        """Handle header bar button presses."""
        if event.button.id == "theme-btn":
            self.action_toggle_dark()
        elif event.button.id == "quit-btn":
            self.app.quit()

    def watch_status_text(self, new_text: str) -> None:
        """Update status label when status_text changes."""
        try:
            label = self.query_one("#status-label", Label)
            label.update(new_text)
        except Exception:
            pass

    def watch_status_running(self, is_running: bool) -> None:
        """Update status indicator style when running state changes."""
        try:
            label = self.query_one("#status-label", Label)
            if is_running:
                label.add_class("status-running")
            else:
                label.remove_class("status-running")
        except Exception:
            pass

    def action_refresh(self) -> None:
        self.refresh_roster()

    def action_export_ical(self) -> None:
        content = generate_ical_content()
        if content:
            path = os.path.join(EXPORT_DIR, f"Roster_{datetime.now().strftime('%Y%m%d')}.ics")
            with open(path, "w", encoding="utf-8") as f: f.write(content)
            self.notify(f"Đã xuất file: {path}")
        else: self.notify("Không có dữ liệu để xuất", severity="warning")

    def action_export_csv(self) -> None:
        content = generate_csv_content()
        if content:
            path = os.path.join(EXPORT_DIR, f"Roster_{datetime.now().strftime('%Y%m%d')}.csv")
            with open(path, "w", encoding="utf-8") as f: f.write(content)
            self.notify(f"Đã xuất file: {path}")
        else: self.notify("Không có dữ liệu để xuất", severity="warning")

    def action_scan(self) -> None:
        self.status_running = True
        self.status_text = "Đang quét..."
        self.run_worker(self.do_ingest_once(), thread=True, name="ingest_worker")

    async def do_ingest_once(self):
        files = glob.glob(os.path.join(AUTO_INGEST_DIR, "*"))
        targets = [f for f in files if f.lower().endswith(('.xlsx', '.csv', '.xls'))]
        if not targets:
            self.status_running = False
            self.status_text = "Sẵn sàng"
            return
        
        self.call_from_thread(lambda: setattr(self, 'status_text', f"Xử lý {len(targets)} file..."))
        aliases = get_aliases()
        regex = compile_alias_regex(aliases)
        count = 0
        for f_path in targets:
            fname = os.path.basename(f_path)
            try:
                with open(f_path, 'rb') as f:
                    results = parse_file(f, fname, regex)
                    if results:
                        save_entries_bulk(consolidate_file_results(results))
                        os.remove(f_path)
                        count += 1
                    else:
                        # No data found, rename to .nodata
                        os.rename(f_path, f_path + ".nodata")
                        self.notify(f"Không tìm thấy dữ liệu trong {fname}", severity="warning")
            except ValueError as ve:
                os.rename(f_path, f_path + ".date_err")
                self.notify(f"Lỗi ngày tháng trong {fname}: {str(ve)}", severity="error")
            except Exception as e:
                self.notify(f"Lỗi xử lý {fname}: {str(e)}", severity="error")
        
        if count > 0:
            self.notify(f"Đã xử lý {count} file thành công!")
            self.call_from_thread(self.refresh_roster)
        
        self.status_running = False
        self.status_text = f"Sẵn sàng ({count} file)" if count > 0 else "Sẵn sàng"

    def refresh_roster(self):
        container = self.query_one("#roster-list")
        container.remove_children()
        history = load_history()
        for idx, item in enumerate(history):
            data = json.loads(item['full_data'])
            # First card auto-expands
            container.mount(RosterCard(item['work_date'], data, is_first=(idx == 0)))

    def action_edit_aliases(self) -> None:
        def after_edit(changed):
            if changed:
                self.notify("Đã cập nhật danh sách tên")
        self.push_screen(AliasModal(), after_edit)

if __name__ == "__main__":
    RosterApp().run()
