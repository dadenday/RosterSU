src_file = os.path.expanduser('~/rosterapp.py')\
with open(src_file) as f:\
    source = f.read()\
\
# ---- only the three critical changes ----\
\
# 1. MD5 вГ¶Г≤ SHA-256\
source = source.replace('hashlib.md5(', 'hashlib.sha256(')\
\
# 2. add filename sanitiser *inside* archive_file body\
source = re.sub(\
    r'(def archive_file\(content, filename, extracted_date=\"Unknown\"\):)',\
    r'\1\n    filename = re.sub(r\"[^A-Za-z0-9._-]\", \"_\", filename)',\
    source\
)\
\
# 3. PIN вГ¶Г≤ bcrypt\
source = source.replace('pin TEXT', 'pin_hash TEXT')\
source = re.sub(r'SET pin = \?', r'SET pin_hash = bcrypt.hashpw(?.encode(), bcrypt.gensalt(12))', source)\
source = re.sub(r'pin = \?', r'pin_hash = bcrypt.hashpw(pin.encode(), bcrypt.gensalt(12))', source)\
source = re.sub(r'if pin_in\.value == row\["pin"\]', 'if secrets.compare_digest(pin_in.value.encode(), row[\"pin_hash\"])', source)\
\
# 4. bare except вГ¶Г≤ log\
source = re.sub(r'except:\s*pass', 'except Exception as e: print(\"PATCH-LOG\", e)', source)\
\
with open(src_file, 'w') as f:\
    f.write(source)\
"\
\
######## 3. install bcrypt #####################################\
pip install -q bcrypt\
\
######## 4. run ################################################\
python ~/rosterapp.py\

