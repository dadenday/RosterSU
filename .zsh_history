import re, os\
\
file = os.path.expanduser("~/rosterapp.py")\
with open(file) as f:\
    src = f.read()\
\
# ---- minimal, safe changes ----\
\
# A. add imports right after the first "import" block\
src = re.sub(\
    r"^(import \w+)$",\
    r"\1\nimport bcrypt, secrets, hashlib",\
    src, flags=re.M, count=1\
)\
\
# B. MD5 вГ¶Г≤ SHA-256\
src = src.replace("hashlib.md5(", "hashlib.sha256(")\
\
# C. sanitise filename inside archive_file()\
src = re.sub(\
    r"(\ndef archive_file\(content, filename, extracted_date=\"Unknown\"\):)",\
    r"\1\n    filename = re.sub(r'[^A-Za-z0-9._-]', '_', filename)",\
    src\
)\
\
# D. PIN вГ¶Г≤ bcrypt hash\
src = src.replace("pin TEXT", "pin_hash TEXT")\
src = re.sub(r"SET pin = \?", r"SET pin_hash = bcrypt.hashpw(?.encode(), bcrypt.gensalt(12))", src)\
src = re.sub(r"pin = \?", r"pin_hash = bcrypt.hashpw(pin.encode(), bcrypt.gensalt(12))", src)\
src = re.sub(\
    r'if pin_in\.value == row\["pin"\]',\
    'if secrets.compare_digest(pin_in.value.encode(), row["pin_hash"])',\
    src\
)\
\
# E. bare except вГ¶Г≤ log\
src = re.sub(r"except:\s*pass", 'except Exception as e: print("PATCH-LOG", e)', src)\
\
with open(file, "w") as f:\
    f.write(src)\
EOF\
