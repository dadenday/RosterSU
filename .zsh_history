# 2. inline Python-patcher (no sed, no perl)\
python3 - <<'FIX'\
import re, os, shutil, sys\
app = os.path.expanduser("~/rosterapp.py")\
txt = open(app).read()\
\
# ---- minimal critical fixes ----\
\
# A. add bcrypt + secrets imports\
txt = re.sub(r"^import nicegui", "import bcrypt, secrets, re\nimport nicegui", txt, flags=re.M, count=1)\
\
# B. MD5 вГ¶Г≤ SHA-256\
txt = txt.replace("hashlib.md5(", "hashlib.sha256(")\
\
# C. sanitise filename in archive_file\
txt = re.sub(\
    r"(def archive_file\(content, filename, extracted_date=\"Unknown\"\):)",\
    r"\1\n    filename = re.sub(r'[^A-Za-z0-9._-]', '_', filename)",\
    txt\
)\
\
# D. PIN вГ¶Г≤ bcrypt hash\
txt = txt.replace("pin TEXT", "pin_hash TEXT")\
txt = re.sub(r"SET pin = \?", r"SET pin_hash = bcrypt.hashpw(?.encode(), bcrypt.gensalt(12))", txt)\
txt = re.sub(r"pin = \?", r"pin_hash = bcrypt.hashpw(pin.encode(), bcrypt.gensalt(12))", txt)\
txt = re.sub(r'if pin_in\.value == row\["pin"\]', 'if secrets.compare_digest(pin_in.value.encode(), row["pin_hash"])', txt)\
\
# E. bare except вГ¶Г≤ log\
txt = re.sub(r"except:\s*pass", 'except Exception as e: print("PATCH-LOG", e)', txt)\
\
open(app, "w").write(txt)\
FIX\
\
# 3. install bcrypt if missing\
pip install -q bcrypt\
\
# 4. start the app\
python ~/rosterapp.py\

