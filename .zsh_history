: 1768800719:0;# 1. roll back to original\
cp ~/rosterapp.py.bak ~/rosterapp.py\
\
# 2. create a **tiny** patcher that does **only** whatвАГєs needed\
python3 - <<'EOF'\
import re, os, shutil, tempfile\
\
src = os.path.expanduser("~/rosterapp.py")\
with open(src) as f:\
    lines = f.readlines()\
\
out = tempfile.NamedTemporaryFile(mode="w", delete=False, suffix=".py")\
for ln in lines:\
    # A. add imports right after first вАГЉimportвАГљ line\
    if ln.startswith("import ") and "bcrypt" not in ln:\
        out.write(ln)\
        out.write("import bcrypt, secrets, hashlib\n")\
        continue\
\
    # B. MD5 вГ¶Г≤ SHA-256\
    ln = ln.replace("hashlib.md5(", "hashlib.sha256(")\
\
    # C. sanitise filename inside archive_file\
    if ln.strip() == "def archive_file(content, filename, extracted_date=\"Unknown\"):":\
        out.write(ln)\
        out.write("    filename = re.sub(r'[^A-Za-z0-9._-]', '_', filename)\n")\
        continue\
\
    # D. PIN вГ¶Г≤ bcrypt\
    ln = ln.replace("pin TEXT", "pin_hash TEXT")\
    ln = re.sub(r"SET pin = \?", r"SET pin_hash = bcrypt.hashpw(?.encode(), bcrypt.gensalt(12))", ln)\
    ln = re.sub(r"pin = \?", r"pin_hash = bcrypt.hashpw(pin.encode(), bcrypt.gensalt(12))", ln)\
    ln = re.sub(r'if pin_in\.value == row\["pin"\]', 'if secrets.compare_digest(pin_in.value.encode(), row["pin_hash"])', ln)\
\
    # E. bare except вГ¶Г≤ log\
    ln = re.sub(r"except:\s*pass", 'except Exception as e: print("PATCH-LOG", e)', ln)\
\
    out.write(ln)\
\
out.close()\
shutil.move(out.name, src)\
EOF\
\
# 3. install bcrypt once\
pip install -q bcrypt\
\
# 4. run\
python ~/rosterapp.py\

