######### 3. apply the patch line-exact with Python ###########\
python3 -c "\
import difflib, os, shutil\
\
patch_file = os.path.expanduser('~/roster.patch')\
orig_file  = os.path.expanduser('~/rosterapp.py')\
\
with open(patch_file) as pf:\
    patch = pf.read()\
\
# strip the fake --- +++ header lines\
lines = patch.splitlines()\
while lines and not lines[0].startswith('@@'):\
    lines.pop(0)\
\
# reconstruct the patched file\
new_lines = []\
with open(orig_file) as f:\
    old_lines = f.readlines()\
\
# simple unified-diff applier (add/rem/context)\
i = 0\
for l in lines:\
    if l.startswith('@@'):\
        continue\
    if l.startswith('-'):\
        continue   # skip removed line\
    if l.startswith('+'):\
        new_lines.append(l[1:] + '\n')  # add new line\
    else:\
        new_lines.append(old_lines[i])\
        i += 1\
\
# write back\
with open(orig_file, 'w') as f:\
    f.writelines(new_lines)\
"\
\
######### 4. install bcrypt ####################################\
pip install -q bcrypt\
\
######### 5. run ################################################\
python ~/rosterapp.py\

