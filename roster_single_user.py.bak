_DB_REV = 0
_DB_REV_LOCK = threading.Lock()

def bump_db_rev():
    global _DB_REV
    with _DB_REV_LOCK:
        _DB_REV += 1

def format_date_vn(date_str):
    try:
        dt = datetime.strptime(date_str, "%d.%m.%Y")
        days = ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN']
        return f"{days[dt.weekday()]} {dt.strftime('%d.%m.%y')}"
    except Exception:
        return date_str

def format_shift_display(date_str, shift_raw):
    zone = ""
    time_part = shift_raw or "--"
    match = RE_ZONE_PATTERN.search(time_part)
    if match:
        time_part = match.group(1).strip()
        zone = match.group(2).strip().capitalize()
    formatted_date = format_date_vn(date_str)
    if time_part in ("OFF", "HỌC"):
        return f"{formatted_date} | {time_part}"
    display = f"{formatted_date} | {time_part}"
    if zone:
        display += f" | {zone}"
    return display

def shift_color(shift):
    if shift == "OFF": return "negative"
    if shift and "HỌC" in shift: return "info"
    if shift and shift != "--": return "positive"
    return "grey-7"

def shift_text_class(shift):
    if shift == "OFF": return "text-red-600"
    if shift and "HỌC" in shift: return "text-blue-600"
    if shift and shift != "--": return "text-green-700"
    return "text-grey-7"

def build_copy_text(date_str, shift_info, flights):
    display = format_shift_display(date_str, shift_info)
    lines = [display]
    for f in flights:
        row = f"✈ {f.get('Type','')} {f.get('Call','')} {f.get('Route','')} {f.get('Open','')} {f.get('Close','')} {f.get('Bay','')} {f.get('Names','')}"
        lines.append(RE_MULTIPLE_SPACES.sub(' ', row).strip())
    return "\n".join(lines)


@ui.page('/')
def main_page():
    UI_CONNECTED.set()
    state = {'filter': 'All', 'select_mode': False, 'selected': set(), 'last_rev': -1}

    dark = ui.dark_mode(False)

    # --- Header ---
    with ui.header().classes('items-center justify-between glass-header px-4 py-1 h-14 shadow-md'):
        with ui.row().classes('items-center gap-2'):
            ui.icon('auto_awesome', color='white').classes('text-2xl')
            ui.label('RosterMaster').classes('text-2xl font-black text-white tracking-tighter uppercase')
        status_label = ui.label('Sẵn sàng').classes('text-xs font-medium text-slate-400 uppercase tracking-widest')

    # --- Status timer ---
    def poll_status():
        s, _ = try_get_app_status()
        details = s.get('details', '')
        st = s.get('state', 'Idle')
        if details and details != 'Ready':
            status_label.text = f"{st}: {details}"
        else:
            status_label.text = 'Sẵn sàng' if st == 'Idle' else st
        with _DB_REV_LOCK:
            rev = _DB_REV
        if rev != state['last_rev']:
            state['last_rev'] = rev
            roster_list.refresh()

    ui.timer(5.0, poll_status)

    # --- Tabs ---
    with ui.tabs().props('dense align="justify" inline-label').classes('w-full bg-white text-slate-600 shadow-sm') as tabs:
        main_tab = ui.tab('Lịch', icon='calendar_today').props('no-caps')
        config_tab = ui.tab('Cài đặt', icon='tune').props('no-caps')

    with ui.tab_panels(tabs, value=main_tab).classes('w-full p-0 bg-transparent'):
        # ========== MAIN TAB ==========
        with ui.tab_panel(main_tab).classes('p-2 gap-2'):
            # Action row (Modern Glass Buttons)
            with ui.row().classes('w-full gap-2 mb-2 no-wrap'):
                ui.button('QUÉT ZALO', icon='refresh', on_click=lambda: do_scan())\
                    .props('unelevated no-caps').classes('flex-1 h-12 rounded-xl bg-teal-600 text-white font-bold shadow-sm')
                
                with ui.element('div').classes('flex-[1.5] h-12 relative rounded-xl bg-indigo-600 shadow-sm overflow-hidden'):
                    ui.label('TẢI LÊN').classes('absolute-center text-white font-bold pointer-events-none')
                    upload = ui.upload(
                        on_upload=lambda e: handle_upload(e),
                        auto_upload=True, max_files=1,
                    ).props('accept=".xlsx,.xls,.csv" flat color=white').classes('w-full h-full opacity-0')

            # Toolbar row
            with ui.row().classes('w-full items-center justify-between px-1 mb-2'):
                filter_select = ui.select(
                    {'All': 'Tất cả', 'This Month': 'Tháng này'},
                    value='All',
                    on_change=lambda e: on_filter_change(e.value)
                ).props('dense standout rounded-sm').classes('w-32 text-sm font-bold')

                with ui.row().classes('gap-1'):
                    ui.button(icon='refresh', on_click=lambda: roster_list.refresh()).props('flat round dense color=slate-400')
                    ui.button(icon='event', on_click=lambda: do_export_ical()).props('flat round dense color=green-600')
                    ui.button(icon='description', on_click=lambda: do_export_csv()).props('flat round dense color=blue-600')

            # Selection controls
            with ui.row().classes('w-full items-center px-1 mb-2 gap-2'):
                sel_switch = ui.switch('Chế độ chọn', value=False, on_change=lambda e: toggle_select(e.value)).props('dense')
                del_btn = ui.button('Xoá đã chọn', on_click=lambda: do_bulk_delete()).props('flat dense no-caps size=sm color=red')
                del_btn.bind_visibility_from(sel_switch, 'value')

            # Roster list container
            @ui.refreshable
            def roster_list():
                rows = load_history(filter_mode=state['filter'])
                if not rows:
                    with ui.column().classes('w-full items-center py-8 text-grey-5'):
                        ui.icon('event_note', size='48px').classes('opacity-40')
                        ui.label('Chưa có dữ liệu').classes('text-sm')
                        ui.label('Tải file hoặc quét tự động để bắt đầu').classes('text-xs')
                    return
                for r in rows:
                    try:
                        d = json.loads(r['full_data'])
                        render_card(r['work_date'], d.get('shift', '--'), d.get('flights', []), state)
                    except Exception:
                        pass

            with ui.column().classes('w-full gap-3'):
                roster_list()

        # ========== CONFIG TAB ==========
        with ui.tab_panel(config_tab).classes('p-4 gap-4'):
            alias_file = "v42_aliases.txt"
            aliases = ""
            if os.path.exists(alias_file):
                with open(alias_file, 'r', encoding='utf-8') as f:
                    aliases = f.read()
            else:
                aliases = "Ấn, ẨN, Ẩn, Nguyễn Ngọc Ấn, NGỌC ẤN, Nguyễn Ngọc Ẩn, NGỌC ẨN"

            with ui.card().props('flat').classes('w-full p-4 bg-white rounded-2xl shadow-sm border border-slate-100'):
                ui.label('THIẾT LẬP CÁ NHÂN').classes('text-xs font-black text-indigo-600 tracking-widest mb-2')
                ui.label('Tên của bạn (cách nhau bằng dấu phẩy)').classes('text-sm font-medium text-slate-500 mb-1')
                alias_input = ui.textarea(value=aliases).props('outlined dense autogrow')\
                    .classes('w-full bg-slate-50 rounded-lg mb-4 text-sm font-bold')
                ui.button('CẬP NHẬT DANH SÁCH TÊN', on_click=lambda: save_aliases(alias_input.value))\
                    .props('unelevated no-caps color=indigo').classes('w-full h-12 rounded-xl font-bold')

            with ui.card().props('flat').classes('w-full p-4 bg-white rounded-2xl shadow-sm border border-slate-100 mt-4'):
                ui.label('HỆ THỐNG').classes('text-xs font-black text-slate-400 tracking-widest mb-2')
                with ui.row().classes('w-full items-center justify-between mb-4'):
                    ui.label('Chế độ tối (Dark Mode)').classes('text-sm font-medium text-slate-600')
                    ui.switch(on_change=lambda e: dark.set_value(e.value)).props('dense color=indigo')

                ui.separator().classes('mb-4')
                
                async def confirm_clear():
                    result = await ui.run_javascript(
                        'confirm("Bạn có chắc muốn xoá toàn bộ dữ liệu không?")'
                    )
                    if result:
                        clear_db()
                        roster_list.refresh()
                        ui.notify('Đã xoá toàn bộ dữ liệu', type='positive')

                ui.button('XOÁ TOÀN BỘ DỮ LIỆU', icon='delete_forever', on_click=confirm_clear)\
                    .props('unelevated no-caps color=red-1 text-color=red-7').classes('w-full h-12 rounded-xl font-bold')

    # --- Handlers ---
    def on_filter_change(val):
        state['filter'] = val
        roster_list.refresh()

    def toggle_select(val):
        state['select_mode'] = val
        state['selected'].clear()
        roster_list.refresh()

    def save_aliases(text):
        text = text.strip()
        if len(text) > 5000:
            text = text[:5000]
        if text:
            processed = [a.strip() for a in text.split(',') if a.strip()]
            text = ','.join(processed)
        target = os.path.join(os.getcwd(), "v42_aliases.txt")
        expected = os.path.realpath(target)
        current_dir = os.path.realpath('.')
        if not expected.startswith(current_dir) or os.path.basename(expected) != "v42_aliases.txt":
            ui.notify('Lỗi đường dẫn', type='negative')
            return
        with open(target, 'w', encoding='utf-8') as f:
            f.write(text)
        ui.notify('Đã cập nhật tên thành công', type='positive')

    def do_scan():
        if not INGEST_RUNNING.is_set():
            INGEST_RUNNING.set()
            def _scan():
                try:
                    _run_ingest_once()
                finally:
                    bump_db_rev()
            threading.Thread(target=_scan, daemon=True).start()
            ui.notify('Đang quét thư mục Zalo...', type='info')
        else:
            ui.notify('Đang xử lý...', type='warning')

    def handle_upload(e: UploadEventArguments):
        content = e.content.read()
        filename = e.name
        if len(content) > MAX_UPLOAD_MB * 1024 * 1024:
            ui.notify('File quá lớn (tối đa 20MB)', type='negative')
            return
        aliases = get_aliases()
        alias_regex = compile_alias_regex(aliases)
        INGEST_RUNNING.set()
        try:
            results, err = process_file_stream(io.BytesIO(content), filename, alias_regex)
            if results:
                final = consolidate_file_results(results)
                count = 0
                for res in final:
                    save_entry_overwrite(res['date'], res)
                    count += 1
                ui.notify(f'Đã nhập {count} ngày từ {filename}', type='positive')
                roster_list.refresh()
            elif err:
                ui.notify(f'Lỗi: {err}', type='negative')
            else:
                ui.notify('Không tìm thấy dữ liệu trong file', type='info')
        except Exception as ex:
            ui.notify(f'Lỗi: {str(ex)}', type='negative')
        finally:
            INGEST_RUNNING.clear()
        upload.reset()

    def do_export_ical():
        content = generate_ical_content()
        if not content:
            ui.notify('Không có dữ liệu để xuất', type='warning')
            return
        ui.download(content.encode('utf-8'), f"Roster_Export_{datetime.now().strftime('%Y%m%d')}.ics")

    def do_export_csv():
        content = generate_csv_content()
        if not content:
            ui.notify('Không có dữ liệu để xuất', type='warning')
            return
        ui.download(content.encode('utf-8'), f"Roster_Export_{datetime.now().strftime('%Y%m%d')}.csv")

    def do_bulk_delete():
        dates = list(state['selected'])
        if not dates:
            ui.notify('Chưa chọn ngày nào', type='warning')
            return
        dates = [d for d in dates if RE_DATE.match(d)]
        if dates:
            with DB_LOCK:
                conn = get_db()
                try:
                    placeholders = ','.join('?' for _ in dates)
                    conn.execute(f"DELETE FROM work_schedule WHERE work_date IN ({placeholders})", tuple(dates))
                    conn.commit()
                finally:
                    conn.close()
            ui.notify(f'Đã xoá {len(dates)} ngày', type='positive')
        state['selected'].clear()
        state['select_mode'] = False
        roster_list.refresh()


def render_card(date_str, shift_info, flights, state):
    color = shift_color(shift_info)
    txt_cls = shift_text_class(shift_info)
    
    # Split display components for better styling
    vn_date = format_date_vn(date_str)
    
    zone = ""
    time_part = shift_info or "--"
    match = RE_ZONE_PATTERN.search(time_part)
    if match:
        time_part = match.group(1).strip()
        zone = match.group(2).strip().upper()

    with ui.card().props('flat').classes('w-full p-0 shiny-card mb-2 overflow-hidden shadow-sm'):
        # Color bar indicator
        ui.element('div').classes(f'status-line bg-{color}')
        
        with ui.row().classes('w-full p-4 items-center justify-between no-wrap gap-4'):
            # Selection & Date/Shift info
            with ui.row().classes('items-center gap-4 flex-1 min-w-0 no-wrap'):
                if state['select_mode']:
                    ui.checkbox(value=date_str in state['selected'], 
                               on_change=lambda e, d=date_str: _toggle_sel(e.value, d, state)).props('dense')
                
                with ui.column().classes('gap-0'):
                    ui.label(vn_date).classes('text-xs font-bold text-slate-400 uppercase tracking-widest')
                    ui.label(time_part).classes(f'big-date {txt_cls} truncate')
                    if zone:
                        ui.label(zone).classes('text-[10px] font-black text-slate-300 tracking-tighter')

            # Action Buttons
            with ui.column().classes('items-end gap-1'):
                copy_text = build_copy_text(date_str, shift_info, flights)
                ui.button(icon='content_copy', on_click=lambda t=copy_text: _copy(t))\
                    .props('flat dense round size=md color=slate-400').classes('hover:bg-slate-100')
                
                if flights:
                    ui.badge(f'{len(flights)} Flights', color='slate-200', text_color='slate-600')\
                        .classes('text-[10px] font-bold px-1 rounded-sm')

        if flights:
            with ui.expansion('CHI TIẾT CHUYẾN BAY', icon='flight_takeoff').props('dense').classes('w-full text-[10px] font-bold text-slate-400 border-t border-slate-50'):
                with ui.element('div').classes('px-4 pb-4 w-full overflow-x-auto'):
                    cols = [
                        {'name': 'Call', 'label': 'Call', 'field': 'Call', 'align': 'left'},
                        {'name': 'Route', 'label': 'Route', 'field': 'Route', 'align': 'left'},
                        {'name': 'Open', 'label': 'Time', 'field': 'Open', 'align': 'left'},
                        {'name': 'Bay', 'label': 'Bay', 'field': 'Bay', 'align': 'center'},
                        {'name': 'Names', 'label': 'Names', 'field': 'Names', 'align': 'left'},
                    ]
                    # Format flights for compact display
                    compact_flights = []
                    for f in flights:
                        compact_flights.append({
                            'Call': f.get('Call',''),
                            'Route': f.get('Route',''),
                            'Open': f"{f.get('Open','')} - {f.get('Close','')}",
                            'Bay': f.get('Bay',''),
                            'Names': f.get('Names','')
                        })
                    
                    ui.table(columns=cols, rows=compact_flights).props('dense flat square hide-bottom hide-pagination')\
                        .classes('bg-slate-50 rounded-lg border border-slate-100')


def _toggle_sel(checked, date_str, state):
    if checked:
        state['selected'].add(date_str)
    else:
        state['selected'].discard(date_str)

async def _copy(text):
    await ui.clipboard.write(text)
    ui.notify('Đã sao chép', type='positive', position='bottom', timeout=1500)


# ==========================================
# 🚀 MAIN ENTRY
# ==========================================

if __name__ in {"__main__", "builtins"}:
    debug_log("Application starting", "MAIN")
    debug_log(f"Debug mode is {'enabled' if DEBUG_ENABLED else 'disabled'}", "MAIN")
    init_db()
    threading.Thread(target=run_auto_ingest, daemon=True).start()
    threading.Thread(target=auto_open_launcher, daemon=True).start()
    debug_log(f"Serving application on port {DEFAULT_PORT}", "MAIN")
    ui.run(port=DEFAULT_PORT, reload=False, show=False, title='RosterMaster', host='127.0.0.1')
